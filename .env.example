# =============================================================================
# Hei FastAPI — 应用配置
# =============================================================================
APP__NAME=hei-fastapi
APP__VERSION=1.0.0
APP__DEBUG=true
APP__HOST=127.0.0.1
APP__PORT=18885
APP__UPLOAD_MAX_SIZE=52428800
APP__IMPORT_MAX_FILE_SIZE_MB=10
APP__TIMEOUT_KEEP_ALIVE=15

# =============================================================================
# MySQL 数据库 — 连接池与性能配置
# =============================================================================
DB__HOST=localhost
DB__PORT=3306
DB__USER=root
DB__PASSWORD=your-db-password
DB__DATABASE=hei_data
DB__POOL_SIZE=20
DB__MAX_OVERFLOW=10
DB__POOL_RECYCLE=3600
DB__POOL_PRE_PING=true
DB__POOL_TIMEOUT=30
DB__CONNECT_TIMEOUT=10
DB__ECHO=false

# =============================================================================
# Redis — 连接池与超时配置
# =============================================================================
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__PASSWORD=your-redis-password
REDIS__DATABASE=1
REDIS__MAX_CONNECTIONS=200
REDIS__SOCKET_CONNECT_TIMEOUT=10
REDIS__SOCKET_TIMEOUT=30
REDIS__RETRY_ON_TIMEOUT=true
REDIS__HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Token 认证
# =============================================================================
TOKEN__EXPIRE_SECONDS=2592000
TOKEN__TOKEN_NAME=Authorization

# =============================================================================
# SM2 国密加密
# =============================================================================
SM2__PRIVATE_KEY=your-sm2-private-key
SM2__PUBLIC_KEY=your-sm2-public-key

# =============================================================================
# CORS 跨域
# =============================================================================
CORS__ALLOW_ORIGINS=["*"]
CORS__ALLOW_METHODS=["*"]
CORS__ALLOW_HEADERS=["*"]
CORS__ALLOW_CREDENTIALS=false

# =============================================================================
# Snowflake ID 生成器
# =============================================================================
SNOWFLAKE__INSTANCE=1

# # Base configuration loaded first.
# # Environment-specific override file is selected by APP_ENV or APP__ENV:
# #   APP_ENV=dev  -> .env.dev
# #   APP_ENV=prod -> .env.prod
# #
# # Precedence:
# #   .env < .env.${APP_ENV} < process environment variables

# APP_ENV=dev

# APP__NAME=hei-fastapi
# APP__ENV=dev
# APP__DEBUG=false
# APP__HOST=0.0.0.0
# APP__PORT=18886
# APP__THREADPOOL_TOKENS=0

# DB__HOST=127.0.0.1
# DB__PORT=3306
# DB__USER=root
# DB__PASSWORD=replace-with-strong-db-password
# DB__DATABASE=hei
# DB__POOL_SIZE=20
# DB__MAX_OVERFLOW=10

# REDIS__HOST=127.0.0.1
# REDIS__PORT=6379
# REDIS__PASSWORD=replace-with-strong-redis-password
# REDIS__DATABASE=1

# TOKEN__EXPIRE_SECONDS=2592000
# TOKEN__TOKEN_NAME=Authorization

# SM2__PRIVATE_KEY=replace-with-private-key
# SM2__PUBLIC_KEY=replace-with-public-key

# SWAGGER__ENABLED=false
# CORS__ALLOW_ORIGINS=["http://localhost:3000"]

# USER__RESET_PASSWORD=replace-with-temporary-reset-password

# STORAGE__DEFAULT=LOCAL
# STORAGE__LOCAL__UPLOAD_FOLDER=./uploads

) ENGINE = InnoDB CHARACTER SET = utf8mb4 COLLATE = utf8mb4_general_ci COMMENT = 'д»Јз Ғз”ҹжҲҗй…ҚзҪ®' ROW_FORMAT = DYNAMIC;


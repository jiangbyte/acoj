-- ----------------------------
-- Table structure for sys_notice
-- ----------------------------
DROP TABLE IF EXISTS `sys_notice`;
CREATE TABLE `sys_notice`  (
  `id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'дё»й”®',
  `title` varchar(255) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'йҖҡзҹҘж Үйўҳ',
  `summary` varchar(500) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT NULL COMMENT 'йҖҡзҹҘж‘ҳиҰҒ',
  `content` text CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL COMMENT 'йҖҡзҹҘеҶ…е®№',
  `cover` varchar(500) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT NULL COMMENT 'е°ҒйқўеӣҫзүҮ',
  `category` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'йҖҡзҹҘзұ»еҲ«',
  `type` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'йҖҡзҹҘзұ»еһӢ',
  `level` varchar(16) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT 'NORMAL' COMMENT 'йҖҡзҹҘзә§еҲ«',
  `view_count` int NULL DEFAULT 0 COMMENT 'жөҸи§Ҳж¬Ўж•°',
  `is_top` varchar(8) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT 'NO' COMMENT 'жҳҜеҗҰзҪ®йЎ¶',
  `position` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT NULL COMMENT 'йҖҡзҹҘдҪҚзҪ®',
  `status` varchar(16) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT 'ENABLED' COMMENT 'зҠ¶жҖҒ',
  `sort_code` int NULL DEFAULT 0 COMMENT 'жҺ’еәҸ',
  `is_deleted` varchar(8) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT 'NO' COMMENT 'йҖ»иҫ‘еҲ йҷӨ',
  `created_at` datetime NULL DEFAULT NULL COMMENT 'еҲӣе»әж—¶й—ҙ',
  `created_by` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT NULL COMMENT 'еҲӣе»әз”ЁжҲ·',
  `updated_at` datetime NULL DEFAULT NULL COMMENT 'жӣҙж–°ж—¶й—ҙ',
  `updated_by` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT NULL COMMENT 'жӣҙж–°з”ЁжҲ·',
  PRIMARY KEY (`id`) USING BTREE,
  INDEX `idx_category_type`(`category` ASC, `type` ASC) USING BTREE,
  INDEX `idx_status`(`status` ASC) USING BTREE
) ENGINE = InnoDB CHARACTER SET = utf8mb4 COLLATE = utf8mb4_general_ci COMMENT = 'йҖҡзҹҘ' ROW_FORMAT = DYNAMIC;

-- ----------------------------
-- Records of sys_notice
-- ----------------------------
INSERT INTO `sys_notice` VALUES ('100001', 'зі»з»ҹеҚҮзә§з»ҙжҠӨйҖҡзҹҘ', 'зі»з»ҹе°ҶдәҺжң¬е‘Ёе…ӯеҮҢжҷЁ2:00-6:00иҝӣиЎҢеҚҮзә§з»ҙжҠӨ', '<h1>зі»з»ҹеҚҮзә§з»ҙжҠӨ</h1><p>дёәдәҶжҸҗдҫӣжӣҙеҘҪзҡ„жңҚеҠЎпјҢзі»з»ҹе°ҶдәҺжң¬е‘Ёе…ӯеҮҢжҷЁ2:00-6:00иҝӣиЎҢеҚҮзә§з»ҙжҠӨпјҢжңҹй—ҙйғЁеҲҶеҠҹиғҪеҸҜиғҪж— жі•жӯЈеёёдҪҝз”ЁгҖӮ</p>', NULL, 'PLATFORM', 'MAINTENANCE', 'IMPORTANT', 0, 'YES', 'TOP', 'ENABLED', 1, 'NO', '2026-05-12 14:55:53', '50001', '2026-05-12 14:55:53', '50001');
INSERT INTO `sys_notice` VALUES ('100002', 'ж¬ўиҝҺдҪҝз”Ё Hei FastAPI зі»з»ҹ', 'ж¬ўиҝҺеҗ„дҪҚеҗҢдәӢдҪҝз”Ёе…Ёж–°ејҖеҸ‘зҡ„еҗҺеҸ°з®ЎзҗҶзі»з»ҹ', '<p>Hei FastAPI жҳҜдёҖеҘ—еҹәдәҺ FastAPI + SQLAlchemy 2.0 зҡ„еҗҺеҸ°з®ЎзҗҶзі»з»ҹпјҢж¬ўиҝҺеӨ§е®¶дҪ“йӘҢе№¶жҸҗдҫӣе®қиҙөж„Ҹи§ҒгҖӮ</p>', NULL, 'PLATFORM', 'SYSTEM_NOTICE', 'NORMAL', 0, 'NO', 'TOP', 'ENABLED', 2, 'NO', '2026-05-12 14:55:53', '50001', '2026-05-12 14:55:53', '50001');
INSERT INTO `sys_notice` VALUES ('100003', 'з¬¬дёүеӯЈеәҰе·ҘдҪңжҖ»з»“дјҡи®®йҖҡзҹҘ', 'иҜ·еҗ„йғЁй—ЁиҙҹиҙЈдәәеҮҶеӨҮз¬¬дёүеӯЈеәҰе·ҘдҪңжҖ»з»“жҠҘе‘Ҡ', '<p>е…¬еҸёе°ҶдәҺдёӢе‘Ёдә”еҸ¬ејҖз¬¬дёүеӯЈеәҰе·ҘдҪңжҖ»з»“дјҡи®®пјҢиҜ·еҗ„йғЁй—ЁиҙҹиҙЈдәәеҮҶеӨҮзӣёе…іжқҗж–ҷгҖӮ</p>', NULL, 'COMPANY', 'BUSINESS_NOTICE', 'IMPORTANT', 0, 'NO', NULL, 'ENABLED', 3, 'NO', '2026-05-12 14:55:53', '50001', '2026-05-12 14:55:53', '50001');
INSERT INTO `sys_notice` VALUES ('100004', 'е…ідәҺеҗҜз”Ёж–°зі»з»ҹзҡ„йҖҡзҹҘ', 'еҚіж—Ҙиө·жӯЈејҸеҗҜз”Ёе…Ёж–°еҗҺеҸ°з®ЎзҗҶзі»з»ҹ', '<p>з»ҸиҝҮејҖеҸ‘еӣўйҳҹзҡ„дёҚжҮҲеҠӘеҠӣпјҢе…Ёж–°еҗҺеҸ°з®ЎзҗҶзі»з»ҹе·ІдәҺд»Ҡж—ҘжӯЈејҸдёҠзәҝпјҢж—§зі»з»ҹе°Ҷе№¶иЎҢиҝҗиЎҢдёҖдёӘжңҲеҗҺдёӢзәҝгҖӮ</p>', NULL, 'PLATFORM', 'SYSTEM_NOTICE', 'NORMAL', 0, 'NO', NULL, 'ENABLED', 4, 'NO', '2026-05-12 14:55:53', '50001', '2026-05-12 14:55:53', '50001');


-- ----------------------------
-- Table structure for rel_user_permission
-- ----------------------------
DROP TABLE IF EXISTS `rel_user_permission`;
CREATE TABLE `rel_user_permission`  (
  `id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'дё»й”®',
  `user_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'з”ЁжҲ·ID',
  `permission_code` varchar(255) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'жқғйҷҗзј–з Ғ',
  `scope` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT 'ALL' COMMENT 'ж•°жҚ®иҢғеӣҙпјҡALL-е…ЁйғЁпјҢSELF-жң¬дәәпјҢORG-жң¬з»„з»ҮпјҢORG_AND_BELOW-жң¬з»„з»ҮеҸҠд»ҘдёӢпјҢCUSTOM_ORG-иҮӘе®ҡд№үз»„з»ҮпјҢGROUP-жң¬з”ЁжҲ·з»„пјҢGROUP_AND_BELOW-жң¬з”ЁжҲ·з»„еҸҠд»ҘдёӢпјҢCUSTOM_GROUP-иҮӘе®ҡд№үз”ЁжҲ·з»„',
  `custom_scope_group_ids` text CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL COMMENT 'иҮӘе®ҡд№үз”ЁжҲ·з»„IDеҲ—иЎЁ(JSONж•°з»„)пјҢscope=CUSTOM_GROUPж—¶з”ҹж•Ҳ',
  `custom_scope_org_ids` text CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL COMMENT 'иҮӘе®ҡд№үз»„з»ҮIDеҲ—иЎЁ(JSONж•°з»„)пјҢscope=CUSTOM_ORGж—¶з”ҹж•Ҳ',
  PRIMARY KEY (`id`) USING BTREE,
  UNIQUE INDEX `uk_user_permission`(`user_id` ASC, `permission_code` ASC) USING BTREE,
  INDEX `idx_permission_code`(`permission_code` ASC) USING BTREE
) ENGINE = InnoDB CHARACTER SET = utf8mb4 COLLATE = utf8mb4_general_ci COMMENT = 'з”ЁжҲ·-жқғйҷҗзӣҙе…іиҒ”' ROW_FORMAT = DYNAMIC;

-- ----------------------------
-- Records of rel_user_permission
-- ----------------------------

-- ----------------------------
-- Table structure for rel_user_role
-- ----------------------------
DROP TABLE IF EXISTS `rel_user_role`;
CREATE TABLE `rel_user_role`  (
  `id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'дё»й”®',
  `user_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'з”ЁжҲ·ID',
  `role_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'и§’иүІID',
  `scope` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT NULL COMMENT 'ж•°жҚ®иҢғеӣҙиҰҶзӣ–пјҡALL-е…ЁйғЁпјҢCUSTOM-иҮӘе®ҡд№үпјҢORG-жң¬з»„з»ҮпјҢORG_AND_BELOW-жң¬з»„з»ҮеҸҠд»ҘдёӢпјҢSELF-жң¬дәәгҖӮдёәз©әеҲҷз»§жүҝ rel_role_permission зҡ„й…ҚзҪ®',
  `custom_scope_group_ids` text CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL COMMENT 'иҮӘе®ҡд№үж•°жҚ®иҢғеӣҙз»„IDеҲ—иЎЁ(JSONж•°з»„)пјҢscope=CUSTOMж—¶з”ҹж•Ҳ',
  PRIMARY KEY (`id`) USING BTREE,
  UNIQUE INDEX `uk_user_role`(`user_id` ASC, `role_id` ASC) USING BTREE,
  INDEX `idx_role_id`(`role_id` ASC) USING BTREE
) ENGINE = InnoDB CHARACTER SET = utf8mb4 COLLATE = utf8mb4_general_ci COMMENT = 'з”ЁжҲ·-и§’иүІе…іиҒ”' ROW_FORMAT = DYNAMIC;


  INDEX `idx_permission_code`(`permission_code` ASC) USING BTREE
) ENGINE = InnoDB CHARACTER SET = utf8mb4 COLLATE = utf8mb4_general_ci COMMENT = 'и§’иүІ-жқғйҷҗе…іиҒ”' ROW_FORMAT = DYNAMIC;


DROP TABLE IF EXISTS `rel_org_role`;
CREATE TABLE `rel_org_role`  (
  `id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'дё»й”®',
  `org_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'з»„з»ҮID',
  `role_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL COMMENT 'и§’иүІID',
  `scope` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL DEFAULT NULL COMMENT 'ж•°жҚ®иҢғеӣҙиҰҶзӣ–пјҡALL-е…ЁйғЁпјҢSELF-жң¬дәәпјҢORG-жң¬з»„з»ҮпјҢORG_AND_BELOW-жң¬з»„з»ҮеҸҠд»ҘдёӢпјҢCUSTOM_ORG-иҮӘе®ҡд№үз»„з»ҮпјҢGROUP-жң¬з”ЁжҲ·з»„пјҢGROUP_AND_BELOW-жң¬з”ЁжҲ·з»„еҸҠд»ҘдёӢпјҢCUSTOM_GROUP-иҮӘе®ҡд№үз”ЁжҲ·з»„гҖӮдёәз©әеҲҷз»§жүҝ rel_role_permission зҡ„й…ҚзҪ®',
  `custom_scope_group_ids` text CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL COMMENT 'иҮӘе®ҡд№үз”ЁжҲ·з»„IDеҲ—иЎЁ(JSONж•°з»„)пјҢscope=CUSTOM_GROUPж—¶з”ҹж•Ҳ',
  `custom_scope_org_ids` text CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NULL COMMENT 'иҮӘе®ҡд№үз»„з»ҮIDеҲ—иЎЁ(JSONж•°з»„)пјҢscope=CUSTOM_ORGж—¶з”ҹж•Ҳ',
  PRIMARY KEY (`id`) USING BTREE,
  UNIQUE INDEX `uk_org_role`(`org_id` ASC, `role_id` ASC) USING BTREE,
  INDEX `idx_role_id`(`role_id` ASC) USING BTREE
) ENGINE = InnoDB CHARACTER SET = utf8mb4 COLLATE = utf8mb4_general_ci COMMENT = 'з»„з»Ү-и§’иүІе…іиҒ”' ROW_FORMAT = DYNAMIC;


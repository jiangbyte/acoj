@router.post(
    "/api/v1/{{ route_prefix }}:import",
    summary="导入{{ EntityName }}数据",
    response_model=Result
)
@HeiCheckPermission("{{ route_prefix }}:import")
async def import_data(
    request: Request,
    file: UploadFile = File(...),
    db: Session = Depends(get_db)
):
    validate_import_file(file)
    content = await file.read()
    wb = load_workbook(io.BytesIO(content))
    ws = wb.active

    headers = [cell.value for cell in ws[1] if cell.value]
    data_list = []

    for row in ws.iter_rows(min_row=2, values_only=True):
        if not any(row):
            continue
        row_dict = {}
        for i, header in enumerate(headers):
            if i < len(row):
                row_dict[header] = row[i]
        data_list.append({{ EntityName }}VO(**row_dict))

    service = {{ EntityName }}Service(db)
    result = await service.import_data({{ EntityName }}ImportParam(data=data_list), request)
    return success(result)

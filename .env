# =============================================================================
# Hei FastAPI — 应用配置
# =============================================================================
APP__NAME=hei-fastapi
APP__VERSION=1.0.0
APP__DEBUG=true
APP__HOST=127.0.0.1
APP__PORT=18886
APP__UPLOAD_MAX_SIZE=52428800
APP__IMPORT_MAX_FILE_SIZE_MB=10
APP__TIMEOUT_KEEP_ALIVE=15

# =============================================================================
# MySQL 数据库 — 连接池与性能配置
# =============================================================================
DB__HOST=127.0.0.1
DB__PORT=3306
DB__USER=root
DB__PASSWORD=123456
DB__DATABASE=hei
DB__POOL_SIZE=20
DB__MAX_OVERFLOW=10
DB__POOL_RECYCLE=3600
DB__POOL_PRE_PING=true
DB__POOL_TIMEOUT=30
DB__CONNECT_TIMEOUT=10
DB__ECHO=false

# =============================================================================
# Redis — 连接池与超时配置
# =============================================================================
REDIS__HOST=127.0.0.1
REDIS__PORT=6379
REDIS__PASSWORD=123456
REDIS__DATABASE=1
REDIS__MAX_CONNECTIONS=200
REDIS__SOCKET_CONNECT_TIMEOUT=10
REDIS__SOCKET_TIMEOUT=30
REDIS__RETRY_ON_TIMEOUT=true
REDIS__HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Token 认证
# =============================================================================
TOKEN__EXPIRE_SECONDS=2592000
TOKEN__TOKEN_NAME=Authorization

# =============================================================================
# SM2 国密加密
# =============================================================================
SM2__PRIVATE_KEY=dbc1da701ba293538f8d1df7d7286410503e25723a99e82c47b0c276dcbf86c0
SM2__PUBLIC_KEY=043fcdbc656c5489a327060548c66c7af746baf31a6bfa04eb0215951e17dd272c8d87ce1da014b26952163143df32e07c0c5ed7000f409dc3e28729f7073469d2

# =============================================================================
# CORS 跨域
# =============================================================================
CORS__ALLOW_ORIGINS=["*"]
CORS__ALLOW_METHODS=["*"]
CORS__ALLOW_HEADERS=["*"]
CORS__ALLOW_CREDENTIALS=false

# =============================================================================
# Snowflake ID 生成器
# =============================================================================
SNOWFLAKE__INSTANCE=1

# =============================================================================
# User 设置
# =============================================================================
USER__RESET_PASSWORD=123456

# =============================================================================
# Storage 存储
# =============================================================================
STORAGE__DEFAULT=LOCAL
STORAGE__DEFAULT_BASE_URL=http://localhost:18885
STORAGE__LOCAL__UPLOAD_FOLDER=./uploads

AUTH__CONSUMER_REALM_PATTERNS=["/api/v1/c/*","/api/v1/public/c/*"]
AUTH__BUSINESS_REALM_PATTERNS=["/api/v1/b/*","/api/v1/public/b/*","/api/v1/sys/*","/api/v1/client/*","/api/v1/client-user/*"]

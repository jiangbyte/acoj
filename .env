# ============================================================================
# hei-fastapi environment example
# 说明：
# 1. 配置使用双下划线 `__` 做嵌套分组，例如 `APP__PORT`
# 2. 默认面向 PostgreSQL + RabbitMQ + S3/MinIO 的完整项目形态
# 3. 轻量部署不需要新增专门的配置项，直接通过以下现有配置组合实现：
#    - REDIS__ENABLED=false
#    - AUTH__ENABLE_MEMORY_SESSION_FALLBACK=true
#    - STORAGE__PROVIDER=local
#    - OBSERVABILITY__ENABLED=false
# 4. 可观测性为可选开启，默认关闭，不强依赖 Prometheus / OTel / 额外 agent
# ============================================================================

# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
APP__NAME=hei-fastapi
APP__HOST=0.0.0.0
APP__PORT=8000
APP__DEBUG=true
APP__API_PREFIX=/api/v1
APP__TIMEZONE=Asia/Shanghai

CORS__ALLOW_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ----------------------------------------------------------------------------
# DATABASE
# PostgreSQL + asyncpg
# ----------------------------------------------------------------------------
DB__URL=postgresql+asyncpg://postgres:123456@127.0.0.1:5432/hei_fastapi
DB__ECHO=true
DB__POOL_SIZE=10
DB__MAX_OVERFLOW=20

# ----------------------------------------------------------------------------
# REDIS
# 说明：
# - 关闭时，会话存储可按 AUTH__ENABLE_MEMORY_SESSION_FALLBACK 回退到内存
# - 轻量部署建议保持关闭，生产建议开启
# - 密码通过 URL 传递，例如：redis://:123456@127.0.0.1:6379/0
# ----------------------------------------------------------------------------
REDIS__URL=redis://127.0.0.1:6379/0
REDIS__ENABLED=true

# ----------------------------------------------------------------------------
# AUTH
# 说明：
# - token 使用随机字符串
# - Redis 关闭时，若允许内存回退，则会话仅保存在当前进程内
# - 多副本部署下不建议依赖内存回退
# ----------------------------------------------------------------------------
AUTH__TOKEN_NAME=Authorization
AUTH__TOKEN_TTL_SECONDS=2592000
AUTH__REFRESH_TTL_SECONDS=2592000
AUTH__ENABLE_MEMORY_SESSION_FALLBACK=true

# ----------------------------------------------------------------------------
# CELERY / RABBITMQ
# 说明：
# - 当前仅配置 RabbitMQ broker
# - 若当前阶段暂不启动 worker，可保留默认值但不运行 Celery 进程
# ----------------------------------------------------------------------------
CELERY__BROKER_URL=amqp://admin:123456@127.0.0.1:5672//

# ----------------------------------------------------------------------------
# STORAGE
# 说明：
# - 默认使用 S3 兼容存储，适配 AWS S3 / MinIO
# - 轻量部署或本地开发可切换为 local，避免依赖对象存储服务
# ----------------------------------------------------------------------------
# STORAGE__PROVIDER=s3
STORAGE__PROVIDER=local
STORAGE__BUCKET=hei-fastapi
STORAGE__ENDPOINT=http://127.0.0.1:9000
STORAGE__ACCESS_KEY=admin
STORAGE__SECRET_KEY=123456
STORAGE__REGION=us-east-1
STORAGE__USE_SSL=false
STORAGE__PRESIGN_EXPIRE_SECONDS=3600
STORAGE__BASE_URL=
STORAGE__LOCAL_ROOT=./storage

# ----------------------------------------------------------------------------
# SNOWFLAKE ID
# 说明：
# - 主键使用雪花 ID 字符串
# - worker_id / datacenter_id 在多实例部署时应避免重复
# ----------------------------------------------------------------------------
ID_GENERATOR__WORKER_ID=1
ID_GENERATOR__DATACENTER_ID=1

# ----------------------------------------------------------------------------
# SWAGGER
# ----------------------------------------------------------------------------
SWAGGER__ENABLED=true

# ----------------------------------------------------------------------------
# OBSERVABILITY
# 说明：
# - 默认关闭，适合轻量部署或极简部署
# - 开启总开关后，再按需打开日志 JSON、metrics、tracing、OTLP 导出
# - 若只想保留普通日志，可继续保持 OBSERVABILITY__ENABLED=false
# ----------------------------------------------------------------------------
OBSERVABILITY__ENABLED=false
OBSERVABILITY__SERVICE_NAME=hei-fastapi
OBSERVABILITY__SERVICE_VERSION=0.1.0
OBSERVABILITY__ENVIRONMENT=dev
OBSERVABILITY__LOG_ENABLED=true
OBSERVABILITY__LOG_LEVEL=INFO
OBSERVABILITY__LOG_JSON=false
OBSERVABILITY__METRICS_ENABLED=false
OBSERVABILITY__METRICS_PATH=/metrics
OBSERVABILITY__TRACING_ENABLED=false
OBSERVABILITY__OTLP_ENABLED=false
OBSERVABILITY__OTLP_ENDPOINT=
OBSERVABILITY__SAMPLE_RATIO=1.0
OBSERVABILITY__CELERY_OBSERVABILITY_ENABLED=false
OBSERVABILITY__DB_OBSERVABILITY_ENABLED=false
OBSERVABILITY__HTTP_CLIENT_OBSERVABILITY_ENABLED=false

# ----------------------------------------------------------------------------
# Profile Example: Lightweight Deployment
# ----------------------------------------------------------------------------
# REDIS__ENABLED=false
# AUTH__ENABLE_MEMORY_SESSION_FALLBACK=true
# STORAGE__PROVIDER=local
# OBSERVABILITY__ENABLED=false

# ----------------------------------------------------------------------------
# Profile Example: Full Environment
# ----------------------------------------------------------------------------
# REDIS__ENABLED=true
# STORAGE__PROVIDER=s3
# OBSERVABILITY__ENABLED=true
# OBSERVABILITY__LOG_JSON=true
# OBSERVABILITY__METRICS_ENABLED=true
# OBSERVABILITY__TRACING_ENABLED=true
# OBSERVABILITY__OTLP_ENABLED=true
# OBSERVABILITY__OTLP_ENDPOINT=http://127.0.0.1:4318
# OBSERVABILITY__DB_OBSERVABILITY_ENABLED=true
# OBSERVABILITY__HTTP_CLIENT_OBSERVABILITY_ENABLED=true
# OBSERVABILITY__CELERY_OBSERVABILITY_ENABLED=true

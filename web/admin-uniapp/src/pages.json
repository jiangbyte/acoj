{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-pro/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/dashboard/index",
      "style": {
        "navigationBarTitleText": "首页",
        "enablePullDownRefresh": true,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/workbench/index",
      "style": {
        "navigationBarTitleText": "工作台",
        "enablePullDownRefresh": true,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/auth/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/message/index",
      "style": {
        "navigationBarTitleText": "消息",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/usercenter/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/usercenter/profile/index",
      "style": {
        "navigationBarTitleText": "个人资料",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/resource/list/index",
      "style": {
        "navigationBarTitleText": "管理列表",
        "navigationStyle": "custom",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/resource/form/index",
      "style": {
        "navigationBarTitleText": "编辑",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/resource/detail/index",
      "style": {
        "navigationBarTitleText": "详情",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/resource/grant/index",
      "style": {
        "navigationBarTitleText": "授权",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/resource/buttons/index",
      "style": {
        "navigationBarTitleText": "按钮权限",
        "navigationStyle": "custom"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#2979ff",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/dashboard/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/workbench/index",
        "text": "工作台"
      },
      {
        "pagePath": "pages/message/index",
        "text": "消息"
      },
      {
        "pagePath": "pages/usercenter/index",
        "text": "我的"
      }
    ]
  }
}
